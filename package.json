  "scripts": {
    "db:migrate": "npx drizzle-kit migrate",
    "db:migrate:local": "dotenv -e .env.development.local -- npx drizzle-kit migrate",
    "db:generate": "npx drizzle-kit generate",
    "start": "tsc && nodemon src/index.ts",
    "start:local": "dotenv -e .env.development.local -- ts-node src/index.ts",
    "start:online": "dotenv -e .env.development -- ts-node src/index.ts",
    "build": "rm -rf ./build && tsc",
    "serve": "node build/index.js",
    "lint": "eslint --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --verbose"
  },
  "keywords": [],
